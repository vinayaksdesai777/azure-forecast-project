{
    "name": "ds_adls_parquet",
    "type": "Microsoft.DataFactory/factories/datasets",
    "properties": {
        "linkedServiceName": {
            "referenceName": "ls_adls_gen2",
            "type": "LinkedServiceReference"
        },
        "parameters": {
            "containerName": {
                "type": "string"
            },
            "folderPath": {
                "type": "string"
            }
        },
        "type": "Parquet",
        "typeProperties": {
            "location": {
                "type": "AzureBlobFSLocation",
                "folderPath": {
                    "value": "@dataset().folderPath",
                    "type": "Expression"
                },
                "fileSystem": {
                    "value": "@dataset().containerName",
                    "type": "Expression"
                }
            }
        },
        "annotations": [],
        "description": "Parameterized dataset for Parquet files in ADLS"
    }
}
